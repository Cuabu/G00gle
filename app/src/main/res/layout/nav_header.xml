<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="176dp"
    android:background="#1A73E8"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="16dp"
    android:theme="@style/ThemeOverlay.AppCompat.Dark"
    tools:showIn="@layout/activity_main">

    <!-- Logotipo o Ícono de la aplicación -->
    <ImageView
        android:id="@+id/navHeaderIcon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginBottom="12dp"
        android:contentDescription="Logo G00gle"
        android:src="@mipmap/ic_launcher_round" />

    <!-- Título principal -->
    <TextView
        android:id="@+id/navHeaderTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="G00gle_App"
        android:textAppearance="@style/TextAppearance.AppCompat.Body2"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Subtítulo o descripción corta -->
    <TextView
        android:id="@+id/navHeaderSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Gestión y Alquiler Vehicular"
        android:textColor="#E0E0E0"
        android:textSize="14sp" />

</LinearLayout>